# direnv: only needed if you run `uv lock` / rebuild lock on the host (not for day-to-day Docker workflow).
# Run `direnv allow` once after editing this file.
export CUDA_HOME="${CUDA_HOME:-/usr/local/cuda-12.4}"
PATH_add "${CUDA_HOME}/bin"
export TORCH_CUDA_ARCH_LIST="${TORCH_CUDA_ARCH_LIST:-7.0;7.5;8.0;8.6;8.9;9.0+PTX}"
